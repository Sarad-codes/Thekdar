@model global::EmployeeModel
@{
    ViewData["Title"] = $"Worker Dashboard - {Model.FirstName} {Model.LastName}";
    Layout = "_Layout";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" asp-route-tab="workers" class="btn btn-outline-secondary">Back to Reports</a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h2 class="mb-2">@Model.FullName</h2>
            <div class="row">
                <div class="col-md-4"><strong>Trade:</strong> @Model.Trade</div>
                <div class="col-md-4"><strong>Email:</strong> @(Model.Email ?? "-")</div>
                <div class="col-md-4"><strong>Daily Rate:</strong> NPR @Model.DailyRate.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Current Active Jobs</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Job Title</th>
                            <th>Client</th>
                            <th>Address</th>
                            <th>Role</th>
                            <th>Assigned By</th>
                            <th>Assigned At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="activeJobsTableBody">
                        <tr><td colspan="7" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Completed Jobs History</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Job Title</th>
                            <th>Client</th>
                            <th>Completed Date</th>
                            <th>Role</th>
                            <th>Assigned By</th>
                            <th>Assigned At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="completedJobsTableBody">
                        <tr><td colspan="7" class="text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const workerId = '@Model.Id';

    $(document).ready(function () {
        loadDashboardData();
    });

    function loadDashboardData() {
        $.ajax({
            url: `/Report/GetWorkerDashboardData/${workerId}`,
            type: 'GET',
            success: function (response) {
                if (response.success) {
                    renderActiveJobsTable(response.activeJobs);
                    renderCompletedJobsTable(response.completedJobsList);
                }
            }
        });
    }

    function renderActiveJobsTable(jobs) {
        if (!jobs || jobs.length === 0) {
            $('#activeJobsTableBody').html('<tr><td colspan="7" class="text-center text-muted">No active jobs</td></tr>');
            return;
        }

        let html = '';
        jobs.forEach(j => {
            html += `<tr>
                        <td class="fw-semibold">${escapeHtml(j.jobTitle)}</td>
                        <td>${escapeHtml(j.clientName || '-')}</td>
                        <td>${escapeHtml(j.address || '-')}</td>
                        <td><span class="badge bg-info">${escapeHtml(j.role)}</span></td>
                        <td>${escapeHtml(j.assignedBy || '-')}</td>
                        <td>${escapeHtml(j.assignedAt || '-')}</td>
                        <td><a href="/Job/Details/${j.jobId}" target="_blank" class="btn btn-sm btn-outline-secondary">View</a></td>
                    </tr>`;
        });
        $('#activeJobsTableBody').html(html);
    }

    function renderCompletedJobsTable(jobs) {
        if (!jobs || jobs.length === 0) {
            $('#completedJobsTableBody').html('<tr><td colspan="7" class="text-center text-muted">No completed jobs</td></tr>');
            return;
        }

        let html = '';
        jobs.forEach(j => {
            html += `<tr>
                        <td class="fw-semibold">${escapeHtml(j.jobTitle)}</td>
                        <td>${escapeHtml(j.clientName || '-')}</td>
                        <td>${escapeHtml(j.completedDate || '-')}</td>
                        <td><span class="badge bg-secondary">${escapeHtml(j.role)}</span></td>
                        <td>${escapeHtml(j.assignedBy || '-')}</td>
                        <td>${escapeHtml(j.assignedAt || '-')}</td>
                        <td><a href="/Job/Details/${j.jobId}" target="_blank" class="btn btn-sm btn-outline-secondary">View</a></td>
                    </tr>`;
        });
        $('#completedJobsTableBody').html(html);
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>
}
