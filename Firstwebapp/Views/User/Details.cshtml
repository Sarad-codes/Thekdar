@model Thekdar.Models.UserModel
@using Thekdar.Models

@{
    ViewData["Title"] = "Contractor Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="fas fa-user-tie me-2"></i>Contractor Details</h4>
                </div>
                <div class="card-body">
                    <!-- Avatar + Name + Role badge -->
                    <div class="text-center mb-4">
                        @if (Model.ProfilePicture != null)
                        {
                            <img src="@Url.Action("GetProfilePicture", "User", new { id = Model.Id })"
                                 alt="@Model.Name"
                                 class="rounded-circle"
                                 id="contractorDetailsProfilePreview"
                                 role="button"
                                 tabindex="0"
                                 title="Click to enlarge"
                                 aria-label="View profile picture larger"
                                 style="width: 100px; height: 100px; object-fit: cover; border: 3px solid #3b82f6; cursor: pointer;" />
                        }
                        else
                        {
                            <i class="fas fa-user-circle fa-5x text-primary"></i>
                        }
                        <h3 class="mt-3 mb-1">@Model.Name</h3>
                        @if (Model.Role == UserRole.Admin)
                        {
                            <span class="badge bg-danger px-3 py-2">
                                <i class="fas fa-crown me-1"></i>Administrator
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-primary px-3 py-2">
                                <i class="fas fa-hard-hat me-1"></i>Contractor
                            </span>
                        }
                    </div>

                    <table class="table table-bordered">
                        <tr>
                            <th class="bg-light" style="width: 40%">
                                <i class="fas fa-envelope me-2 text-muted"></i>Email
                            </th>
                            <td>@Model.Email</td>
                        </tr>
                         <tr>
                            <th class="bg-light">
                                <i class="fas fa-phone me-2 text-muted"></i>Phone
                            </th>
                            <td>@Model.Phone</td>
                        </tr>
                        <tr>
                            <th class="bg-light">
                                <i class="fas fa-calendar-alt me-2 text-muted"></i>Age
                            </th>
                            <td>@Model.Age</td>
                        </tr>
                        <tr>
                            <th class="bg-light">
                                <i class="fas fa-user-tag me-2 text-muted"></i>Role
                            </th>
                            <td>
                                @if (Model.Role == UserRole.Admin)
                                {
                                    <span class="badge bg-danger">Administrator</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Contractor</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th class="bg-light">
                                <i class="fas fa-shield-alt me-2 text-muted"></i>Status
                            </th>
                            <td>
                                @if (Model.Status == UserStatus.Active)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th class="bg-light">
                                <i class="fas fa-clock me-2 text-muted"></i>Joined
                            </th>
                            <td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    </table>

                    <div class="d-flex gap-2">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning flex-fill">
                                <i class="fas fa-edit me-2"></i>Edit Contractor
                            </a>
                        }
                        <a asp-action="List" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-arrow-left me-2"></i>Back to Contractors
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="contractorDetailsPictureEnlargeModal" tabindex="-1" aria-labelledby="contractorDetailsPictureEnlargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 bg-dark">
            <div class="modal-header border-secondary border-opacity-25 py-2">
                <h5 class="modal-title text-white small mb-0" id="contractorDetailsPictureEnlargeModalLabel">Profile picture</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-3">
                <img id="contractorDetailsPictureEnlargeImg" src="" alt="" class="img-fluid rounded" style="max-height: min(85vh, 720px); object-fit: contain;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        const thumb = document.getElementById('contractorDetailsProfilePreview');
        const modalEl = document.getElementById('contractorDetailsPictureEnlargeModal');
        const modalImg = document.getElementById('contractorDetailsPictureEnlargeImg');
        if (!thumb || !modalEl || !modalImg || typeof bootstrap === 'undefined') return;

        const modal = new bootstrap.Modal(modalEl);
        function openEnlarge() {
            modalImg.src = thumb.currentSrc || thumb.src;
            modalImg.alt = thumb.alt || 'Profile picture';
            modal.show();
        }
        thumb.addEventListener('click', openEnlarge);
        thumb.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openEnlarge();
            }
        });
    })();
</script>
}