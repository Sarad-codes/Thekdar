@model EmployeeViewModel
@{
    ViewData["Title"] = "Edit Worker";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Worker</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="IsDeleted" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        @if (Model.IsDeleted)
                        {
                            <div class="alert alert-warning" role="alert">
                                <i class="fas fa-user-slash me-2"></i>
                                This worker is deactivated. You can update their details here, but they will stay unavailable until an admin reactivates them.
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.ExistingProfilePicturePath))
                        {
                            <div class="text-center mb-4">
                                <img src="@Model.ExistingProfilePicturePath" 
                                     alt="@Model.FullName" 
                                     class="rounded-circle" 
                                     style="width: 100px; height: 100px; object-fit: cover; border: 3px solid #3b82f6;" />
                                <p class="text-muted mt-1 small">Current Profile Picture</p>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold"></label>
                                <input asp-for="FirstName" class="form-control" id="FirstName" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Trade" class="form-label fw-bold"></label>
                                <input asp-for="Trade" class="form-control" placeholder="e.g., Mason, Carpenter, Electrician" />
                                <span asp-validation-for="Trade" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DailyRate" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">NPR</span>
                                    <input asp-for="DailyRate" class="form-control" type="number" step="100" />
                                </div>
                                <span asp-validation-for="DailyRate" class="text-danger"></span>
                                <small class="text-muted">Daily wage in Nepali Rupees (NPR)</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-bold"></label>
                                <input asp-for="Phone" class="form-control" placeholder="10-digit phone number" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                                <small class="text-muted">Required - Must be exactly 10 digits</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone2" class="form-label fw-bold">Secondary Phone (Optional)</label>
                                <input asp-for="Phone2" class="form-control" placeholder="10-digit phone number" />
                                <span asp-validation-for="Phone2" class="text-danger"></span>
                                <small class="text-muted">Optional - Must be exactly 10 digits if provided</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold"></label>
                                <input asp-for="Email" class="form-control" type="email" id="Email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="HireDate" class="form-label fw-bold"></label>
                                <input asp-for="HireDate" class="form-control" type="date" />
                                <span asp-validation-for="HireDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PanNumber" class="form-label fw-bold">PAN Number (Optional)</label>
                                <input asp-for="PanNumber" class="form-control" />
                                <span asp-validation-for="PanNumber" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="IsAvailable" class="form-label fw-bold"></label>
                                @if (Model.IsDeleted)
                                {
                                    <input type="hidden" asp-for="IsAvailable" value="false" />
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" disabled />
                                        <label class="form-check-label text-muted">Unavailable while deactivated</label>
                                    </div>
                                }
                                else
                                {
                                    <div class="form-check">
                                        <input asp-for="IsAvailable" class="form-check-input" />
                                        <label asp-for="IsAvailable" class="form-check-label">Available for work</label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProfilePicture" class="form-label fw-bold">Change Profile Picture (Optional)</label>
                                <input asp-for="ProfilePicture" class="form-control" type="file" accept="image/*" />
                                <small class="text-muted">Leave empty to keep current. Max 5MB</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PanCardImage" class="form-label fw-bold">Change PAN Card Image (Optional)</label>
                                <input asp-for="PanCardImage" class="form-control" type="file" accept="image/*" />
                                <small class="text-muted">Leave empty to keep current. Max 5MB</small>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ExistingPanCardPath))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Current PAN Card Image</label>
                                <div>
                                    <img src="@Model.ExistingPanCardPath" alt="PAN Card" style="max-height: 100px;" class="border rounded" />
                                </div>
                            </div>
                        }

                        <!-- ========== MOBILE LOGIN SECTION ========== -->
                        <div class="card mt-4 mb-4 border-primary">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0"><i class="fas fa-mobile-alt me-2"></i>Mobile App Access</h5>
                            </div>
                            <div class="card-body">
                                <div class="form-check mb-3">
                                    <input asp-for="MobileEnabled" class="form-check-input" id="MobileEnabledCheckbox" />
                                    <label asp-for="MobileEnabled" class="form-check-label fw-bold">
                                        Enable mobile app login
                                    </label>
                                    <small class="text-muted d-block">Allow this worker to login to the mobile app</small>
                                </div>

                                <div id="MobileCredentialsSection" style="display: @(Model.MobileEnabled ? "block" : "none");">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Manage mobile access for this worker.
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-8">
                                            <label class="form-label fw-bold">New Password (Optional)</label>
                                            <div class="input-group">
                                                <input type="text" id="MobilePassword" class="form-control" placeholder="Leave empty to keep current" />
                                                <button type="button" id="GeneratePasswordBtn" class="btn btn-outline-secondary">
                                                    <i class="fas fa-sync-alt"></i> Generate
                                                </button>
                                                <button type="button" id="CopyPasswordBtn" class="btn btn-outline-secondary">
                                                    <i class="fas fa-copy"></i> Copy
                                                </button>
                                            </div>
                                            <small class="text-muted">Enter a new password or generate one. Leave empty to keep current password.</small>
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <button type="button" id="ResetPasswordBtn" class="btn btn-warning w-100">
                                                <i class="fas fa-key me-2"></i>Reset Password & Send
                                            </button>
                                        </div>
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(Model.LastMobileLogin))
                                    {
                                        <div class="mt-3 small text-muted">
                                            <i class="fas fa-history me-1"></i> Last login: @Model.LastMobileLogin
                                        </div>
                                    }
                                    
                                    <div id="EmailSentMessage" class="alert alert-success mt-3" style="display: none;">
                                        <i class="fas fa-check-circle me-2"></i> New credentials sent successfully to <strong>@Model.Email</strong>
                                    </div>
                                </div>
                                
                                <div id="MobileRevokeSection" style="display: @(Model.MobileEnabled ? "none" : "block");">
                                    @if (Model.MobileEnabledWas)
                                    {
                                        <div class="alert alert-warning">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            Disabling mobile access will prevent this worker from logging into the mobile app.
                                        </div>
                                        <button type="button" id="RevokeAccessBtn" class="btn btn-outline-danger">
                                            <i class="fas fa-ban me-2"></i>Revoke Access
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                        <!-- ========== END MOBILE LOGIN SECTION ========== -->

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" asp-route-filter="@(Model.IsDeleted ? "Deleted" : "Active")" class="btn btn-outline-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Mobile login checkbox toggle
        $('#MobileEnabledCheckbox').change(function() {
            if ($(this).is(':checked')) {
                $('#MobileCredentialsSection').slideDown();
                $('#MobileRevokeSection').slideUp();
            } else {
                $('#MobileCredentialsSection').slideUp();
                $('#MobileRevokeSection').slideDown();
            }
        });
        
        // Generate password
        function generatePassword() {
            var firstName = $('#FirstName').val() || 'Worker';
            var randomNum = Math.floor(Math.random() * 900 + 100);
            var password = firstName + '@@' + randomNum;
            $('#MobilePassword').val(password);
        }
        
        $('#GeneratePasswordBtn').click(function() {
            generatePassword();
        });
        
        // Copy password
        $('#CopyPasswordBtn').click(function() {
            var passwordInput = $('#MobilePassword');
            passwordInput.select();
            document.execCommand('copy');
            
            var btn = $(this);
            btn.html('<i class="fas fa-check"></i> Copied!');
            setTimeout(function() {
                btn.html('<i class="fas fa-copy"></i> Copy');
            }, 1500);
        });

        $('#ResetPasswordBtn').click(function() {
            var workerId = $('#Id').val();
            var newPassword = $('#MobilePassword').val();
            var email = $('#Email').val();

            if (!email) {
                alert('Worker must have an email address to receive credentials.');
                return;
            }

            if (!newPassword) {
                generatePassword();
                newPassword = $('#MobilePassword').val();
            }

            if (confirm('Send new password to ' + email + '?')) {
                $.ajax({
                    url: '@Url.Action("ResetMobilePassword", "Employee")',
                    type: 'POST',
                    data: {
                        id: workerId,
                        password: newPassword
                    },
                    success: function(response) {
                        if (response.success) {
                            if (response.warning) {
                                alert('⚠️ ' + response.message);
                            } else {
                                alert('✅ ' + response.message);
                            }
                            $('#EmailSentMessage').slideDown();
                            setTimeout(function() {
                                $('#EmailSentMessage').slideUp();
                            }, 3000);
                            $('#MobilePassword').val('');
                        } else {
                            alert('❌ Error: ' + response.message);
                        }
                    },
                    error: function(xhr) {
                        alert('❌ Server error: ' + xhr.status + ' - ' + xhr.statusText);
                    }
                });
            }
});
        
        // Revoke access button
        $('#RevokeAccessBtn').click(function() {
            if (confirm('Are you sure you want to revoke mobile access for this worker?')) {
                $('#MobileEnabledCheckbox').prop('checked', false).trigger('change');
            }
        });
    </script>
}