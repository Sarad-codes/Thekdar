@model Thekdar.Models.JobModel

@{
    ViewData["Title"] = "Delete Job";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Job</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Are you sure you want to delete this job? <strong>This cannot be undone.</strong>
                    </div>

                    <table class="table table-bordered mb-4">
                        <tr>
                            <th class="bg-light" style="width:35%">Title</th>
                            <td class="fw-semibold">@Model.Title</td>
                        </tr>
                        <tr>
                            <th class="bg-light">Client</th>
                            <td>@(Model.ClientName ?? "â€”")</td>
                        </tr>
                        <tr>
                            <th class="bg-light">Address</th>
                            <td>@(Model.Address ?? "â€”")</td>
                        </tr>
                        <tr>
                            <th class="bg-light">Scheduled</th>
                            <td>
                                @(Model.ScheduledDate.HasValue
                                    ? Model.ScheduledDate.Value.ToString("MMM dd, yyyy")
                                    : "â€”")
                            </td>
                        </tr>
                    </table>

                    <div class="d-flex gap-2">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="flex-fill" id="deleteForm">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100" id="deleteBtn">
                                <i class="fas fa-trash me-2"></i>Yes, Delete
                            </button>
                        </form>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Prevent back button issues after deletion
        (function() {
            // Push a new state to prevent direct back navigation to this page after deletion
            window.history.pushState(null, "", window.location.href);
            
            // Handle popstate (back button) events
            window.onpopstate = function() {
                // If user tries to go back, redirect to the jobs index page
                window.location.href = '@Url.Action("Index")';
            };
            
            // Handle form submission
            const deleteForm = document.getElementById('deleteForm');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function() {
                    // Disable button to prevent double submission
                    const deleteBtn = document.getElementById('deleteBtn');
                    if (deleteBtn) {
                        deleteBtn.disabled = true;
                        deleteBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Deleting...';
                    }
                    
                    // Replace the current history entry with the jobs index page
                    const redirectUrl = '@Url.Action("Index")';
                    setTimeout(function() {
                        history.replaceState(null, '', redirectUrl);
                    }, 100);
                });
            }
        })();
    </script>
}