@model List<Thekdar.Models.PayrollModel>
@using Thekdar.Models
@{
    ViewData["Title"] = "Payroll History";
    var totalPaid = Model.Where(p => p.Status == PaymentStatus.Paid).Sum(p => p.NetPayable);
    var totalPending = Model.Where(p => p.Status == PaymentStatus.Pending).Sum(p => p.NetPayable);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2>
            <i class="fas fa-history text-primary me-2"></i>Payroll History
        </h2>
        <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                <i class="fas fa-cog me-2"></i>Actions
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                <li>
                    <a asp-action="Statistics" class="dropdown-item">
                        <i class="fas fa-chart-bar text-info me-2"></i>View Statistics
                    </a>
                </li>
                <li>
                    <a asp-controller="Invoice" asp-action="Index" class="dropdown-item">
                        <i class="fas fa-file-invoice-dollar text-primary me-2"></i>Open Invoices
                    </a>
                </li>
                <li>
                    <a asp-controller="Wage" asp-action="Calculator" class="dropdown-item">
                        <i class="fas fa-calculator text-success me-2"></i>New Calculation
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">From Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">To Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Employee Name</label>
                    <input type="text" name="employeeFilter" class="form-control" value="@ViewBag.EmployeeFilter" placeholder="Search by name..." />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Records</h6>
                    <h2 class="mb-0">@Model.Count</h2>
                    <small>Payroll entries</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Paid</h6>
                    <h2 class="mb-0">NPR @totalPaid.ToString("N0")</h2>
                    <small>@Model.Count(p => p.Status == PaymentStatus.Paid) payments</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h6 class="card-title">Pending</h6>
                    <h2 class="mb-0">NPR @totalPending.ToString("N0")</h2>
                    <small>@Model.Count(p => p.Status == PaymentStatus.Pending) pending</small>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-receipt fa-4x text-muted mb-3"></i>
            <p class="fs-5 text-muted">No payroll records found.</p>
            <a asp-controller="Wage" asp-action="Calculator" class="btn btn-primary">
                <i class="fas fa-calculator me-2"></i>Create First Payroll
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Payslip #</th>
                        <th>Employee</th>
                        <th>Period</th>
                        <th>Days</th>
                        <th>Net Payable</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payroll in Model)
                    {
                         <tr>
                            <td class="fw-semibold">@payroll.PayslipNumber</td>
                            <td>
                                @payroll.Employee?.FullName
                                <br />
                                <small class="text-muted">@payroll.Employee?.Trade</small>
                            </td>
                            <td>@payroll.FormattedPeriod</td>
                            <td>@payroll.DaysWorked</td>
                            <td class="fw-bold text-success">NPR @payroll.NetPayable.ToString("N0")</td>
                            <td>
                                @if (payroll.Status == PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else if (payroll.Status == PaymentStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (payroll.Status == PaymentStatus.PartiallyPaid)
                                {
                                    <span class="badge bg-info text-dark">Partially Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Overdue</span>
                                }
                            </td>
                            <td>
                                <div class="dropdown">
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                            type="button"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        <i class="fas fa-cog me-1"></i>Actions
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                        <li>
                                            <a asp-action="Payslip" asp-route-id="@payroll.Id" class="dropdown-item">
                                                <i class="fas fa-eye text-primary me-2"></i>View Payslip
                                            </a>
                                        </li>
                                        <li>
                                            <a asp-action="Payslip" asp-route-id="@payroll.Id" asp-route-print="true" target="_blank" class="dropdown-item">
                                                <i class="fas fa-print text-secondary me-2"></i>Print Payslip
                                            </a>
                                        </li>
                                    @if (payroll.Status != PaymentStatus.Paid)
                                    {
                                            <li>
                                                <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#paymentModal-@payroll.Id">
                                                    <i class="fas fa-money-bill-wave text-success me-2"></i>Mark as Paid
                                                </button>
                                            </li>
                                    }
                                    @if (ViewBag.IsAdmin)
                                    {
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <button type="button" class="dropdown-item text-danger" onclick="confirmDelete('@payroll.Id')">
                                                    <i class="fas fa-trash me-2"></i>Delete Payroll
                                                </button>
                                            </li>
                                    }
                                    </ul>
                                </div>

                                <!-- Payment Modal -->
                                <div class="modal fade" id="paymentModal-@payroll.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header bg-success text-white">
                                                <h5 class="modal-title">Record Payment</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="MarkAsPaid" method="post">
                                                <div class="modal-body">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@payroll.Id" />
                                                    <div class="mb-3">
                                                        <label class="form-label">Payment Date</label>
                                                        <input type="date" name="paymentDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Payment Method</label>
                                                        <select name="paymentMethod" class="form-select" required>
                                                            <option value="">Select Method</option>
                                                            <option value="Cash">Cash</option>
                                                            <option value="Bank Transfer">Bank Transfer</option>
                                                            <option value="Cheque">Cheque</option>
                                                            <option value="Mobile Payment">Mobile Payment (eSewa, Khalti)</option>
                                                        </select>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Transaction Reference (Optional)</label>
                                                        <input type="text" name="transactionReference" class="form-control" placeholder="Receipt #, Transaction ID" />
                                                    </div>
                                                    <div class="alert alert-info">
                                                        <strong>Amount to Pay:</strong> NPR @payroll.NetPayable.ToString("N0")
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success">Confirm Payment</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this payroll record? This action cannot be undone.')) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}
