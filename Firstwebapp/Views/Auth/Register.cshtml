@model Thekdar.ViewModels.RegisterViewModel
@using Thekdar.Models

@{
ViewData["Title"] = "Register";
Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Register | Thekdar</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://unpkg.com/aos@next/dist/aos.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            width: 100%;
            max-width: 500px;
            animation: slideUp 0.6s ease;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .auth-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px 30px;
            text-align: center;
        }

        .auth-header h1 {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .auth-header p {
            opacity: 0.9;
            margin: 0;
            font-size: 0.95rem;
        }

        .auth-body {
            padding: 30px;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .input-group-text {
            background: transparent;
            border: 2px solid #e0e0e0;
            border-right: none;
            border-radius: 12px 0 0 12px;
            color: #667eea;
        }

        .form-control {
            border: 2px solid #e0e0e0;
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 10px 16px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: none;
            outline: none;
        }

        .input-group:focus-within .input-group-text {
            border-color: #667eea;
        }

        .input-group:focus-within .form-control {
            border-color: #667eea;
        }

        .btn-register {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            width: 100%;
            transition: all 0.3s ease;
            margin-top: 15px;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-register:active {
            transform: translateY(0);
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid #e0e0e0;
        }

        .auth-footer a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .auth-footer a:hover {
            color: #764ba2;
        }

        .text-danger {
            font-size: 0.8rem;
            margin-top: 5px;
            display: block;
            color: #dc3545;
        }

        .text-success {
            font-size: 0.8rem;
            margin-top: 5px;
            display: block;
            color: #198754;
        }

        .floating-icon {
            position: absolute;
            font-size: 15rem;
            color: rgba(255, 255, 255, 0.03);
            z-index: 0;
            pointer-events: none;
        }

        .icon-1 {
            top: 10%;
            left: 5%;
            transform: rotate(-15deg);
        }

        .icon-2 {
            bottom: 10%;
            right: 5%;
            transform: rotate(15deg);
        }

        .role-info {
            background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
            border-radius: 10px;
            padding: 12px;
            margin: 15px 0;
            border: 1px solid #667eea30;
            font-size: 0.9rem;
        }

        .role-info i {
            color: #667eea;
            margin-right: 8px;
        }

        .password-toggle-btn {
            position: relative;
        }

        .password-toggle-btn:hover::after {
            content: attr(title);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            color: white;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 4px;
            white-space: nowrap;
            margin-bottom: 8px;
            z-index: 1000;
            pointer-events: none;
        }

        .password-toggle-btn:hover::before {
            content: '';
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            border: 5px solid transparent;
            border-top-color: #333;
            margin-bottom: 2px;
            z-index: 1000;
            pointer-events: none;
        }

        .valid-feedback-custom {
            color: #198754;
            font-size: 0.8rem;
            margin-top: 5px;
            display: block;
        }

        .is-valid {
            border-color: #198754 !important;
        }

        .is-invalid {
            border-color: #dc3545 !important;
        }
    </style>
</head>
<body>
<div class="floating-icon icon-1">
    <i class="fas fa-briefcase"></i>
</div>
<div class="floating-icon icon-2">
    <i class="fas fa-users"></i>
</div>

<div class="auth-wrapper">
    <div class="auth-card" data-aos="fade-up">
        <div class="auth-header">
            <h1><i class="fas fa-user-plus me-2"></i>Create Account</h1>
            <p>Join Thekdar today</p>
        </div>

        <div class="auth-body">
            <form asp-action="Register" method="post" enctype="multipart/form-data" id="registerForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="border-radius: 10px;"></div>

                <!-- Name -->
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">
                        <i class="fas fa-user me-2"></i>Full Name
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input asp-for="Name" class="form-control" id="fullName" placeholder="Your full name" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <!-- Email with real-time validation -->
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">
                        <i class="fas fa-envelope me-2"></i>Email Address
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" id="emailInput" placeholder="you@email.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" id="emailError"></span>
                    <span class="text-success" id="emailSuccess" style="display: none;">âœ“ Valid email format</span>
                </div>

                <!-- Phone with real-time validation -->
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">
                        <i class="fas fa-phone me-2"></i>Phone Number
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                        <input asp-for="Phone" class="form-control" id="phoneInput" placeholder="10-digit phone number" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger" id="phoneError"></span>
                    <span class="text-success" id="phoneSuccess" style="display: none;">âœ“ Valid phone number</span>
                </div>

                <!-- Age -->
                <div class="mb-3">
                    <label asp-for="Age" class="form-label">
                        <i class="fas fa-calendar-alt me-2"></i>Age
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                        <input asp-for="Age" class="form-control" type="number" id="ageInput" placeholder="Your age" />
                    </div>
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>

                <!-- Profile Picture -->
                <div class="mb-3">
                    <label asp-for="ProfilePicture" class="form-label">
                        <i class="fas fa-camera me-2"></i>Profile Picture
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-image"></i></span>
                        <input asp-for="ProfilePicture" class="form-control" type="file" accept="image/*" id="profilePicInput" />
                    </div>
                    <small class="text-muted">Optional: Upload a profile picture (jpg, png, etc.)</small>
                    <span asp-validation-for="ProfilePicture" class="text-danger small"></span>
                    <div id="imagePreviewContainer" class="mt-2 text-center" style="display: none;">
                        <img id="imagePreview" src="#" alt="Preview" class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover; border: 2px solid #3b82f6;" />
                    </div>
                </div>

                <!-- Password with toggle and strength meter -->
                <div class="mb-3">
                    <label asp-for="Password" class="form-label">
                        <i class="fas fa-lock me-2"></i>Password
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" type="password" id="regPassword" placeholder="Create a password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle-btn"
                                onclick="togglePassword('regPassword', this)"
                                title="Show/Hide password">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <div class="mt-2">
                        <div class="progress" style="height: 4px;">
                            <div id="passwordStrength" class="progress-bar" style="width: 0%; transition: width 0.3s;"></div>
                        </div>
                        <small id="passwordHelp" class="text-muted">Password must be at least 6 characters</small>
                    </div>
                </div>

                <!-- Confirm Password with toggle -->
                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">
                        <i class="fas fa-check-double me-2"></i>Confirm Password
                    </label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" id="confirmPassword" placeholder="Repeat your password" />
                        <button type="button" class="btn btn-outline-secondary password-toggle-btn"
                                onclick="togglePassword('confirmPassword', this)"
                                title="Show/Hide password">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger" id="confirmError"></span>
                    <span class="text-success" id="confirmSuccess" style="display: none;">âœ“ Passwords match</span>
                </div>

                <button type="submit" class="btn-register" id="submitBtn">
                    <i class="fas fa-user-check me-2"></i>Create Account
                </button>
            </form>

            <div class="auth-footer">
                <p class="mb-0">
                    Already have an account?
                    <a asp-action="Login">
                        Sign In <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 800,
        once: true
    });

    function togglePassword(inputId, button) {
        const input = document.getElementById(inputId);
        const icon = button.querySelector('i');

        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    // Email validation
    const emailInput = document.getElementById('emailInput');
    const emailError = document.getElementById('emailError');
    const emailSuccess = document.getElementById('emailSuccess');

    function validateEmail() {
        const email = emailInput.value;
        const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        
        if (email === '') {
            emailError.textContent = '';
            emailSuccess.style.display = 'none';
            emailInput.classList.remove('is-valid', 'is-invalid');
            return false;
        }
        
        if (emailRegex.test(email)) {
            emailError.textContent = '';
            emailSuccess.style.display = 'block';
            emailInput.classList.add('is-valid');
            emailInput.classList.remove('is-invalid');
            return true;
        } else {
            emailError.textContent = 'Please enter a valid email address';
            emailSuccess.style.display = 'none';
            emailInput.classList.add('is-invalid');
            emailInput.classList.remove('is-valid');
            return false;
        }
    }

    // Phone validation
    const phoneInput = document.getElementById('phoneInput');
    const phoneError = document.getElementById('phoneError');
    const phoneSuccess = document.getElementById('phoneSuccess');

    function validatePhone() {
        let value = phoneInput.value.replace(/\D/g, '');
        if (value.length > 10) value = value.slice(0, 10);
        phoneInput.value = value;
        
        if (value === '') {
            phoneError.textContent = '';
            phoneSuccess.style.display = 'none';
            phoneInput.classList.remove('is-valid', 'is-invalid');
            return false;
        }
        
        if (value.length === 10) {
            phoneError.textContent = '';
            phoneSuccess.style.display = 'block';
            phoneInput.classList.add('is-valid');
            phoneInput.classList.remove('is-invalid');
            return true;
        } else {
            phoneError.textContent = 'Phone must be exactly 10 digits';
            phoneSuccess.style.display = 'none';
            phoneInput.classList.add('is-invalid');
            phoneInput.classList.remove('is-valid');
            return false;
        }
    }

    // Password strength meter
    const passwordInput = document.getElementById('regPassword');
    const strengthBar = document.getElementById('passwordStrength');
    const passwordHelp = document.getElementById('passwordHelp');

    function checkPasswordStrength() {
        const value = passwordInput.value;
        let strength = 0;
        let message = '';
        let color = '';
        
        if (value.length >= 6) strength += 25;
        if (value.length >= 10) strength += 25;
        if (/[A-Z]/.test(value)) strength += 25;
        if (/[0-9]/.test(value)) strength += 25;
        
        if (strength === 0) {
            message = 'Password must be at least 6 characters';
            color = '#dc3545';
        } else if (strength <= 25) {
            message = 'Weak - add more characters';
            color = '#dc3545';
        } else if (strength <= 50) {
            message = 'Fair - add uppercase letters or numbers';
            color = '#ffc107';
        } else if (strength <= 75) {
            message = 'Good - almost there!';
            color = '#0dcaf0';
        } else {
            message = 'Strong password!';
            color = '#198754';
        }
        
        strengthBar.style.width = strength + '%';
        strengthBar.style.backgroundColor = color;
        passwordHelp.textContent = message;
        passwordHelp.style.color = color;
        
        validatePasswordMatch();
    }

    // Password match validation
    const confirmInput = document.getElementById('confirmPassword');
    const confirmError = document.getElementById('confirmError');
    const confirmSuccess = document.getElementById('confirmSuccess');

    function validatePasswordMatch() {
        if (confirmInput.value === '') {
            confirmError.textContent = '';
            confirmSuccess.style.display = 'none';
            confirmInput.classList.remove('is-valid', 'is-invalid');
            return;
        }
        
        if (passwordInput.value === confirmInput.value && passwordInput.value !== '') {
            confirmError.textContent = '';
            confirmSuccess.style.display = 'block';
            confirmInput.classList.add('is-valid');
            confirmInput.classList.remove('is-invalid');
        } else {
            confirmError.textContent = 'Passwords do not match';
            confirmSuccess.style.display = 'none';
            confirmInput.classList.add('is-invalid');
            confirmInput.classList.remove('is-valid');
        }
    }

    // Image preview
    const profilePicInput = document.getElementById('profilePicInput');
    const previewContainer = document.getElementById('imagePreviewContainer');
    const previewImage = document.getElementById('imagePreview');

    if (profilePicInput) {
        profilePicInput.addEventListener('change', function(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    previewContainer.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                previewContainer.style.display = 'none';
                previewImage.src = '#';
            }
        });
    }

    // Attach event listeners
    emailInput.addEventListener('input', validateEmail);
    phoneInput.addEventListener('input', validatePhone);
    passwordInput.addEventListener('input', checkPasswordStrength);
    confirmInput.addEventListener('input', validatePasswordMatch);
    
    // Age validation
    const ageInput = document.getElementById('ageInput');
    function validateAge() {
        const age = parseInt(ageInput.value);
        if (age >= 18 && age <= 100) {
            ageInput.classList.add('is-valid');
            ageInput.classList.remove('is-invalid');
        } else if (ageInput.value !== '') {
            ageInput.classList.add('is-invalid');
            ageInput.classList.remove('is-valid');
        } else {
            ageInput.classList.remove('is-valid', 'is-invalid');
        }
    }
    ageInput.addEventListener('input', validateAge);

    // Prevent form submission if validation fails
    const form = document.getElementById('registerForm');
    let submitted = false;

    form.addEventListener('submit', function(e) {
        const isEmailValid = validateEmail();
        const isPhoneValid = validatePhone();
        const isAgeValid = ageInput.value === '' || (parseInt(ageInput.value) >= 18 && parseInt(ageInput.value) <= 100);
        const isPasswordValid = passwordInput.value.length >= 6;
        const isConfirmValid = passwordInput.value === confirmInput.value && passwordInput.value !== '';
        
        if (!isEmailValid || !isPhoneValid || !isAgeValid || !isPasswordValid || !isConfirmValid) {
            e.preventDefault();
            alert('Please fix the validation errors before submitting.');
            return;
        }
        
        if (submitted) {
            e.preventDefault();
            return;
        }
        submitted = true;
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Creating Account...';
    });
</script>
</body>
</html>